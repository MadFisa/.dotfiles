{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing": 0,
  "modules-left": [
    "niri/workspaces",
    "user",
    "temperature",
    "memory",
    "cpu",
    "niri/window"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "custom/pomodoro",
    "bluetooth",
    "network",
    "pulseaudio",
    "backlight",
    "power-profiles-daemon",
    "group/group-power",
    "battery"
  ],

  "group/group-power": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/power", // First element is the "group leader" and won't ever be hidden
      "custom/quit",
      "custom/lock",
      "custom/reboot"
    ]
  },

  "custom/quit": {
    "format": "≤░Ω╝",
    "tooltip": false,
    "on-click": "niri msg action quit"
  },
  "custom/lock": {
    "tooltip": false,
    "on-click": "swaylock",
    "format": "ΎΑμ"
  },
  "custom/reboot": {
    "format": "≤░εΚ",
    "tooltip": false,
    "on-click": "reboot"
  },
  "custom/power": {
    "format": "ΎΑΣ",
    "tooltip": false,
    "on-click": "shutdown now"
  },
  "bluetooth": {
    "format": "≤░Γ▓",
    "format-on": "{icon}",
    "format-off": "{icon}",
    "format-connected": "{icon}",
    "format-icons": {
      "on": "≤░Γψ",
      "off": "≤░Γ▓",
      "connected": "≤░Γ▒"
    },
    "on-click": "blueman-manager",
    "tooltip-format-connected": "{device_enumerate}"
  },

  "custom/music": {
    "format": "ΎΑΒ  {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },

  "clock": {
    "timezone": "Asia/Kolkata",
    "tooltip": true,
    "format-alt": "{:%A, %B %d, %Y (%R)} ΎΩψ ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M:%S  -  %A, %d}",
    "interval": 1,
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "left",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode"
    }
  },

  "network": {
    "format-wifi": "≤░νλ",
    "format-ethernet": "≤░ΙΑ ",
    "format-disconnected": "≤░νι ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"
  },

  "cpu": {
    "interval": 1,
    "format": "ΎΜδ  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
    "on-click": "ghostty -e btop"
  },

  "memory": {
    "interval": 1,
    "format": "Ό┐Ζ  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory",
    "on-click": "ghostty -e btop"
  },

  "custom/uptime": {
    "format": "{}",
    "format-icon": ["ΎΒλ"],
    "tooltip": false,
    "interval": 1600,
    "exec": "$HOME/.config/waybar/scripts/uptime.sh"
  },

  "user": {
    "format": "{work_H} hours ΎΒλ",
    "interval": 60,
    "height": 30,
    "width": 30,
    "icon": true
  },

  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": ["ΌΟΞ", "≤░Δε", "≤░Δδ", "≤░Δη", "≤░Δζ", "≤░Δθ", "≤░Δι"],
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "ΎΣο",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
    "interval": 2,
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "ΎΘο {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-alt": "{icon} {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  },

  "temperature": {
    "thermal-zone": 2,
    // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C ΎΜΘ",
    "format": "{temperatureC}┬░C ΎΜΚ",
    "on-click": "ghostty -e btop"
  },

  "custom/pomodoro": {
    "format": "{}",
    "return-type": "json",
    "exec": "waybar-module-pomodoro --no-work-icons",
    "on-click": "waybar-module-pomodoro toggle",
    "on-click-right": "waybar-module-pomodoro reset"
  },

  "niri/workspaces": {
	"format": "{icon}",
	"format-icons": {
        "main" : "ΌςΖ",
		"browser": "≤░Ψθ",
        "code": "ΎΕκ",
		"chat": "ΎΓΗ",
        "media":"Ό░δ",

		// Icons by state
		"active": "ΎΗΤ",
		"default": "ΎΕΣ"
	}
},
  "niri/window": {
    "format": "{title}",
    "icon": true,
    "max-length": 20,
    "icon-size": 20,
    "rewrite": {
      "(.*) - Mozilla Firefox": "$1",
      "(.*) - Visual Studio Code": "$1",
      "(.*) - Inertia": "ΏθγΑ #$1",
      "^\\s*$": "Dialog"
    }
  }
}
